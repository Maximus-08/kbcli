# Vault Configuration
# Path to your Obsidian Vault root (auto-detection works if run inside the vault)
VAULT_KB_PATH=

# Model Stack Configuration
# Local Ollama model (used for single-doc compilation, fast and free)
COMPILE_MODEL_SINGLE=gemma4:e4b

# Multi-doc compilation, lint checks, queries, and cleanup checks (needs larger context)
COMPILE_MODEL_MULTI=llama-4-scout
LINT_MODEL=llama-4-scout
QUERY_MODEL=llama-4-scout
CLEANUP_MODEL=llama-4-scout

# API Endpoint Configurations
# Local Ollama URL
OLLAMA_BASE_URL=http://localhost:11434

# Cloud Ollama URL (fallback for rate-limited Groq calls)
OLLAMA_CLOUD_BASE_URL=
OLLAMA_CLOUD_API_KEY=

# Groq API Key (disables Groq-dependent features if left empty)
GROQ_API_KEY=

# Gemini API Key (disables Gemini-dependent features if left empty)
GEMINI_API_KEY=

# OpenRouter API Key (disables OpenRouter-dependent features if left empty)
OPENROUTER_API_KEY=

# Watcher Configuration
# Set to true if you are on WSL /mnt/c/ mounts where fsnotify is flaky
WATCHER_POLL_FALLBACK=false

# Number of uncompiled files that triggers a multi-doc suggestion in watch mode
MULTI_DOC_THRESHOLD=5

# Logging Strategy (debug, info, warn, error)
LOG_LEVEL=info
